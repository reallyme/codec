{
  "name": "@reallyme/codec",
  "version": "0.1.21",
  "description": "TypeScript facade for the ReallyMe codec WASM package.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./proto": {
      "types": "./dist/proto.d.ts",
      "default": "./dist/proto.js"
    },
    "./wasm/reallyme_codec_wasm.js": {
      "types": "./dist/wasm/reallyme_codec_wasm.d.ts",
      "default": "./dist/wasm/reallyme_codec_wasm.js"
    },
    "./wasm/reallyme_codec_wasm_bg.wasm": {
      "default": "./dist/wasm/reallyme_codec_wasm_bg.wasm"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && npm run build:wasm && tsc",
    "build:wasm": "node scripts/build-wasm.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"test/*.test.mjs\""
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
